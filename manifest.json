{
  "manifest_version": 3,
  "name": "Organiseret",
  "version": "1.1",
  "description": "Sets a custom new tab page.",
  "homepage_url": "https://github.com/BenjaminEwe/Organiseret-StartPage",

  "icons": {
    "32": "images/flower.svg",
    "48": "images/flower.svg",
    "64": "images/flower.svg",
    "96": "images/flower.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "organiseret@benjamin.ewe",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "chrome_settings_overrides": {
    "homepage": "index.html"
  }
}